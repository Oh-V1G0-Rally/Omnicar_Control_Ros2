<launch>
  <arg name="robot_id" value="$(optenv ROBOT_ID unnamed_robot)"/>

  <group ns="$(arg robot_id)">
    <node pkg="sdpo_ros_odom" type="sdpo_ros_odom_wh_node"
        name="sdpo_ros_odom" clear_params="true"
        output="$(optenv ROBOT_OUTPUT screen)">
      <rosparam command="load" subst_value="True" file="$(find sdpo_ros_odom)/config/sdpo_ros_odom.yaml"/>
    <param name="odom_frame_id" value="$(arg robot_id)/odom" />
    <param name="base_frame_id" value="$(arg robot_id)/base_footprint" />
    </node>
  </group>
</launch>
