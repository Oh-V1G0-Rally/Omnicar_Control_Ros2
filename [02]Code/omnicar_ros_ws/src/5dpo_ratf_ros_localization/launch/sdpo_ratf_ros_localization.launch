<launch>
  <arg name="robot_id" value="$(optenv ROBOT_ID unnamed_robot)"/>

  <group ns="$(arg robot_id)">
    <node pkg="sdpo_ratf_ros_localization"
        type="sdpo_ratf_ros_localization_node" name="sdpo_ratf_ros_localization"
        clear_params="true" output="screen">
      <rosparam command="load" subst_value="True"
          file="$(find sdpo_ratf_ros_localization)/config/sdpo_ratf_ros_localization.yaml"/>
          
          <!-- <remap from="/unnamed_robot/laser_scan_point_cloud" to="/unnamed_robot/scan" /> -->
          <!-- <remap from="laser_scan_point_cloud" to="scan_cloud" /> -->
          <!--<remap from="odom" to="odom" /> -->
	    <param name="map_frame_id"   value="$(arg robot_id)/map" />
	    <param name="odom_frame_id"  value="$(arg robot_id)/odom" />
	    <param name="base_frame_id"  value="$(arg robot_id)/base_footprint" />
	    <param name="laser_frame_id" value="$(arg robot_id)/laser" />
    </node>
  </group>
</launch>
