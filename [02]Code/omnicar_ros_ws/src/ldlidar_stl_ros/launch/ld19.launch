<?xml version="1.0"?>
<launch>
  <arg name="robot_id" default="unnamed_robot"/>
  <!-- <arg name="topic_name" default="/scan"/> -->
  <arg name="port_name" default="/dev/ttyUSB1"/>
  
 <group ns="$(arg robot_id)">
  <node name="LD19" pkg="ldlidar_stl_ros" type="ldlidar_stl_ros_node" output="screen" >
    <rosparam command="load" file="$(find ldlidar_stl_ros)/config/sdpo_driver_laser_2d_LD19.yaml" />

    <param name="base_frame_id" value="$(arg robot_id)/base_footprint" />
    <param name="laser_frame_id" value="$(arg robot_id)/laser" />
    
    <param name="product_name" value="LDLiDAR_LD19"/>
    <param name="port_name"    value="$(arg port_name)"/>
    <param name="port_baudrate" value="230400"/>
    
    <param name="topic_name"   value="scan"/>

    <param name="laser_scan_dir"         type="bool"   value="true"/>
    <param name="enable_angle_crop_func" type="bool"   value="false"/>
    <param name="angle_crop_min"         type="double" value="135.0"/>
    <param name="angle_crop_max"         type="double" value="225.0"/>

    </node>
    

  </group>
  </launch>
