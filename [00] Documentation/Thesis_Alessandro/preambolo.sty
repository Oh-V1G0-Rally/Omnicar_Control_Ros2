% questo nuovo comando \pic serve per inserire le immagini velocemente
% \pic{ nome (senza estensione) }{ posizione }{ dimensione (altezza in centimetri) }{ didascalia }
% posizione: t in cima, b in fondo, p in pagina a parte, H esattamente qui, h circa qui
% per fare riferimenti all'immagine usare il nome del file (senza estensione)
\newcommand{\pic}[4]{
    \begin{figure}[#2]
        \begin{center}
            \includegraphics[height={#3}cm]{#1}
            \caption{#4}
            \label{fig:#1}
        \end{center}
    \end{figure}
}
